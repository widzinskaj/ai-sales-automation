# =============================================================================
# Stage 0 — Environment template
# =============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env — it contains secrets.
#
# Who fills this in: technical operator only.
# Business users do not access this file.
# =============================================================================

# --- Google Sheets ---
# GOOGLE_SHEET_ID: from the spreadsheet URL, between /d/ and /edit
GOOGLE_SHEET_ID=

# Tab names must match the spreadsheet exactly (case-sensitive)
GOOGLE_SHEET_TAB_INPUT=automation_stage0_input
GOOGLE_SHEET_TAB_STATUS=automation_stage0_status

# Path to the Google Cloud service account JSON key file
# The file must NOT be committed to version control (secrets/ is gitignored)
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service_account.json

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# --- Runtime ---
# Static calendar booking link included in every outbound email
# Stage 0 does not use any Calendar API — this is a plain URL
CALENDAR_URL=

# Paths to the 3 PDF attachments sent with every email
# Files must exist at these paths when the job runs (assets/attachments/ is gitignored)
STAGE0_PDF_1=assets/attachments/a.pdf
STAGE0_PDF_2=assets/attachments/b.pdf
STAGE0_PDF_3=assets/attachments/c.pdf

# --- Environment ---
APP_ENV=local

# --- Test Mode ---
# STAGE0_TEST_MODE: mandatory safeguard for development and pre-production testing.
#
#   1 = test mode active:
#       All outbound emails are redirected to TEST_RECIPIENT_EMAIL.
#       Real lead addresses are never contacted.
#       Status writes still happen against the real sheet (fully observable).
#       TEST_RECIPIENT_EMAIL is required when this is set to 1.
#
#   0 = production mode:
#       Emails go to real lead addresses from the input sheet.
#       Only enable after a successful test-mode verification run.
#
# Default: leave set to 1 during all development and testing.
# Set to 0 only when ready for production sends.
STAGE0_TEST_MODE=1

# Required when STAGE0_TEST_MODE=1.
# All emails will be delivered here instead of to real leads.
# Leave empty when STAGE0_TEST_MODE=0.
TEST_RECIPIENT_EMAIL=

# =========================
# Stage 0 – Environment template
# =========================
# Copy this file to .env and fill in real values.
# Never commit .env.

# --- Google Sheets ---
# GOOGLE_SHEET_ID: from Sheet URL between /d/ and /edit
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB_INPUT=automation_stage0_input
GOOGLE_SHEET_TAB_STATUS=automation_stage0_status

# GOOGLE_SERVICE_ACCOUNT_JSON: paste full JSON content as string
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# --- Calendar ---
CALENDAR_URL=

# --- Attachments ---
STAGE0_PDF_1=assets/attachments/a.pdf
STAGE0_PDF_2=assets/attachments/b.pdf
STAGE0_PDF_3=assets/attachments/c.pdf

# --- Environment ---
APP_ENV=local

# --- Test Mode ---
STAGE0_TEST_MODE=1
TEST_RECIPIENT_EMAIL=
